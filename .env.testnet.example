# The shared testnet (Base Sepolia) config. Copy to .env.testnet and run `just dev-testnet`
# (vite --mode testnet). All values are public. Pipeline: contracts -> indexer -> frontend.
VITE_DELIBERATE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RPC_URL=https://sepolia.base.org
# The hosted indexer's GraphQL endpoint (envio.dev). This is the current dev deployment;
# after "Promote to production" in the app, swap in the static production endpoint.
VITE_INDEXER_URL=https://indexer.dev.hyperindex.xyz/123abc/v1/graphql
# Reads are digest-verified, so an untrusted gateway is fine; Pinata's serves the shared
# testnet's pins instantly (public gateways only see them after DHT propagation).
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud
# Author through the hosted pin proxy (api/v0/add.ts on the deployed site), so content pins
# where every reader's gateway finds it. Writes and reads must target the same pinning home:
# a mismatch (e.g. local-kubo writes + Pinata reads) strands content as digests for others.
VITE_IPFS_API=https://frontend-three-psi-vuy2beo6h5.vercel.app
# Offline/throwaway alternative - the dockerized kubo (just ipfs-up) for both:
#   VITE_IPFS_GATEWAY=http://127.0.0.1:8080
#   VITE_IPFS_API=http://127.0.0.1:5001

# Hosted (Vercel): set all of the above as project env vars (VITE_* values are baked into
# the public bundle at build time), with VITE_IPFS_API=/ so authoring publishes through the
# same-origin pin proxy (api/v0/add.ts). The proxy's PINATA_JWT is a server-side Vercel env
# var - never VITE_-prefixed and never in an env file: everything here ships to the browser
# or sits unencrypted on disk.